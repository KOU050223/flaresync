{
  "name": "flaresync-repo",
  "version": "1.0.0",
  "description": "Durable Object state sync library for Cloudflare Workers (monorepo root)",
  "private": true,
  "scripts": {
    "typecheck": "pnpm -r --filter \"./packages/*\" --filter \"./examples/*\" run typecheck",
    "build": "pnpm -r --filter \"./packages/*\" run build",
    "lint": "eslint \"packages/*/src/**/*.ts\" \"examples/*/src/**/*.ts\"",
    "lint:fix": "eslint --fix \"packages/*/src/**/*.ts\" \"examples/*/src/**/*.ts\"",
    "format": "prettier --write \"**/*.{ts,mts,json}\"",
    "format:check": "prettier --check \"**/*.{ts,mts,json}\"",
    "knip": "knip",
    "prepare": "lefthook install"
  },
  "keywords": [],
  "author": "KOU050223 <kouhei20050223@icloud.com>",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-n": "^17.24.0",
    "knip": "^6.6.0",
    "lefthook": "^2.1.6",
    "prettier": "^3.8.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.4"
  }
}
